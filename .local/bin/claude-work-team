#!/usr/bin/env bash
# Generated by claude-code-auth-switch  (do not edit by hand — edit ../.claude-profiles/config.yaml
# and re-run `claude-code-auth-switch/install.py --sync`). Included here only as a reference example.
set -euo pipefail

# Unset inherited CLAUDE_*/ANTHROPIC_* env vars to avoid interference
# when nesting (running from within another Claude Code session).
while IFS= read -r varname; do
  unset "$varname"
done < <(compgen -v | grep -E "^(CLAUDE_|ANTHROPIC_)")

export CLAUDE_CONFIG_DIR="$HOME/.claude-profiles/work-team"
export FP_CC_AUTH_SWITCH_PROFILE="work-team"
export AGENT_BROWSER_AUTO_CONNECT="1"
export DD_SITE="datadoghq.com"
export GITLAB_HOST="gitlab.example.com"
export SLACK_ORG="your-slack-org"

case "${1:-}" in
  mcp|auth|doctor|install|setup-token|update|upgrade|agents|auto-mode|plugin|plugins) exec claude "$@" ;;
esac

# Default model (overridden if --model is passed on command line)
user_args=("$@")
has_model=false
for arg in "$@"; do
  case "$arg" in
    --model|--model=*) has_model=true; break ;;
  esac
done
if [[ "$has_model" == false ]]; then
  user_args+=(--model "claude-opus-4-8[1m]")
fi

exec claude \
  --add-dir "$HOME/devel/projects/work" \
  "${user_args[@]}"
